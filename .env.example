# ===========================================
# SMART BOT STAFF - Environment Variables
# Cole estas variáveis no Netlify: Site Settings → Environment Variables
# ===========================================

# ===========================================
# SUPABASE - Server-side (Netlify Functions)
# ===========================================
SUPABASE_URL=https://SEU_SUPABASE_ID.supabase.co
SUPABASE_ANON_KEY=COLE_SUA_ANON_KEY_AQUI
SUPABASE_SERVICE_ROLE_KEY=COLE_SUA_SERVICE_ROLE_KEY_AQUI

# ===========================================
# SUPABASE - Client-side (Frontend/Vite)
# ===========================================
VITE_SUPABASE_URL=https://SEU_SUPABASE_ID.supabase.co
VITE_SUPABASE_ANON_KEY=COLE_SUA_ANON_KEY_AQUI

# ===========================================
# OPENAI
# ===========================================
OPENAI_API_KEY=COLE_SUA_OPENAI_API_KEY_AQUI

# ===========================================
# TWILIO (WhatsApp)
# ===========================================
TWILIO_ACCOUNT_SID=COLE_SUA_TWILIO_SID_AQUI
TWILIO_AUTH_TOKEN=COLE_SUA_TWILIO_AUTH_TOKEN_AQUI
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ===========================================
# NODE VERSION
# ===========================================
NODE_VERSION=20